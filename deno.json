{
  "name": "@ensj/sudoku",
  "version": "0.1.0",
  "exports": "./src/index.ts",
  "exclude": ["npm/"],
  "tasks": {
    "test": "deno test --allow-read",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/index.ts",
    "build:npm": "deno run -A build_npm.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
